# VIPER Forensic Engine — Environment Config
# Copy to .env: cp .env.example .env

# Device: cuda, cpu, or mps
DEVICE=cuda

# Training (locked by execution plan — do not change)
BATCH_SIZE=64
NUM_EPOCHS=10
LEARNING_RATE=1e-4
NUM_WORKERS=2
SEED=42

# Kaggle credentials (for WikiArt dataset download)
KAGGLE_USERNAME=
KAGGLE_KEY=
